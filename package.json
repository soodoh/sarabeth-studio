{
	"name": "sarabeth-studio",
	"version": "1.1.0",
	"homepage": "https://sarabethbelon.com",
	"private": true,
	"type": "module",
	"author": "Paul DiLoreto <soodohh@pm.me>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/soodoh/sarabeth-portfolio/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/soodoh/sarabeth-studio.git"
	},
	"keywords": [
		"tanstack-start",
		"contentful",
		"react",
		"aws",
		"serverless"
	],
	"packageManager": "bun",
	"scripts": {
		"dev": "vite --port 3000",
		"build": "tsc --noEmit && vite build",
		"build:playwright": "tsc --noEmit && vite build --config vite.playwright.config.ts",
		"start": "node .output/server/index.mjs",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"contentful:snapshot": "bun scripts/record-contentful-snapshot.ts",
		"test:e2e": "playwright test --update-snapshots=none",
		"test:e2e:update": "playwright test --update-snapshots",
		"test:ci": "bun run lint && bun run test:e2e",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@aws-sdk/client-ses": "^3.1085.0",
		"@contentful/rich-text-react-renderer": "^16.2.1",
		"@contentful/rich-text-types": "^17.2.7",
		"@tanstack/react-router": "^1.170.18",
		"@tanstack/react-start": "^1.168.28",
		"@tanstack/start-static-server-functions": "1.167.19",
		"@unpic/react": "^1.0.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"contentful": "^11.12.7",
		"embla-carousel-react": "^8.6.0",
		"lucide-react": "^1.24.0",
		"motion": "^12.42.2",
		"nitro": "^3.0.260610-beta",
		"radix-ui": "^1.6.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"sharp": "^0.35.3",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"unpic": "^4.2.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@commitlint/types": "^21.2.0",
		"@netlify/plugin-lighthouse": "^6.0.4",
		"@playwright/test": "1.61.0",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "26.1.1",
		"@types/react": "^19.2.17",
		"@vitejs/plugin-react": "^6.0.3",
		"lefthook": "^2.1.10",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.4"
	}
}
